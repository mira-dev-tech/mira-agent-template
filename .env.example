# Copie para .env (NÃO commitar). O .env está no .gitignore.

# Login: por padrão `mira login` abre o navegador (device flow) — não precisa de senha aqui.
# Preencha estes só para CI/não-interativo (aí o login usa email+senha):
MIRA_EMAIL=
MIRA_PASSWORD=

# Credenciais de integrações MCP (ex.: VTEX). Só usadas por `mira apply`, nunca commitadas.
VTEX_ACCOUNT=
VTEX_APPKEY=
VTEX_APPTOKEN=
